<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Sentinel</title>
    <!-- We will use Outfit as primary font from Google fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="d-flex" style="min-height: 100vh;">
        <!-- Sidebar Navigation -->
        <div class="glass-panel m-3 d-flex flex-column" style="width: 260px; border-radius: 1.25rem;">
            <div class="mb-5 mt-3 px-2">
                <h2 class="text-gradient m-0" style="font-weight: 700;">Sentinel</h2>
                <small style="color: #cbd5e1; letter-spacing: 0.15em; font-size: 0.75rem; font-weight: 500;">NETWORK MONITOR</small>
            </div>
            
            <ul class="nav flex-column gap-2 mb-auto">
                <li class="nav-item">
                    <a class="nav-link text-white p-3 d-flex align-items-center" asp-area="" asp-controller="Home" asp-action="Index" style="background: rgba(255, 255, 255, 0.05); border-radius: 0.75rem; border: 1px solid rgba(255, 255, 255, 0.05);">
                        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="me-3" style="color: var(--accent-cyan);"><rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect></svg>
                        Dashboard
                    </a>
                </li>
            </ul>

            <div class="mt-auto px-2 pb-2">
                <div class="d-flex align-items-center" style="color: #cbd5e1; font-size: 0.85rem; font-weight: 500;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="me-2" style="color: var(--accent-success);"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
                    System Active
                </div>
            </div>
        </div>

        <!-- Main Workspace -->
        <div class="flex-grow-1 p-4" style="overflow-y: auto; height: 100vh;">
            <main role="main" class="pb-3 h-100">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
